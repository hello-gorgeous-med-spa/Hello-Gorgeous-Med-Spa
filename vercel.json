{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/gift-cards/sync?full=true",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/sales/reconcile",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/review-requests",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/automation/queue/enqueue",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/automation/queue/process",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scheduled-social-posts",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "book.hellogorgeousmedspa.com"
        }
      ],
      "destination": "/book"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "hub.hellogorgeousmedspa.com" }],
      "destination": "/hub"
    }
  ]
}
