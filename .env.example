# ============================================================
# HELLO GORGEOUS OS - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# 
# IMPORTANT: Never commit .env.local to version control!
# ============================================================

# ============================================================
# SUPABASE (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# Public URL - safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key - safe to expose, used for client-side queries
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - KEEP SECRET! Only use server-side
# This key bypasses Row Level Security - never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# HMAC for signed /contour-lift/intake links (Quantum RF clinical intake). 32+ random chars; set in Vercel prod.
# Without this, "Copy intake link" in admin is disabled; dev can fall back only in non-production.
CLINIC_INTAKE_HMAC_SECRET=

# ============================================================
# STRIPE (Required for Payments)
# Get these from: https://dashboard.stripe.com/apikeys
# ============================================================

# Use LIVE keys for production (sk_live_..., pk_live_...)
# Use TEST keys for development (sk_test_..., pk_test_...)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret - get from Stripe Dashboard > Webhooks
# Required to verify webhook events are from Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# PUBLIC BOOKING URL — Square Appointments (lib/flows.ts `BOOKING_URL`)
# Appointments/booking = Square Online Booking. Payments/POS also Square.
# Fresha env vars are legacy; primary CTAs ignore them.
# ============================================================
# Org Square booking URL (override optional — hardcoded default in flows.ts).
# Hello Gorgeous Med Spa RX: location L3QDRS4DX9ZE4 · booking site pf2o75yphk7vw6
# NEXT_PUBLIC_SQUARE_BOOKING_URL=https://square.site/book/L3QDRS4DX9ZE4/hello-gorgeous-med-spa-rx-oswego-il
# NEXT_PUBLIC_SQUARE_APPOINTMENTS_START_URL=https://app.squareup.com/appointments/book/pf2o75yphk7vw6/L3QDRS4DX9ZE4/start
# NP telehealth / $49 program consult (Medical Visit with Ryan):
# NEXT_PUBLIC_SQUARE_RX_TELEHEALTH_URL=https://book.squareup.com/appointments/pf2o75yphk7vw6/location/L3QDRS4DX9ZE4/services/ZLCRRG4BM6W2DCLWDWIDVBPA
# Alias (only used if it is a Square appointments URL):
# NEXT_PUBLIC_BOOKING_URL=https://square.site/book/L3QDRS4DX9ZE4/hello-gorgeous-med-spa-rx-oswego-il
# Server checkouts / memberships:
# SQUARE_LOCATION_ID=L3QDRS4DX9ZE4

# Square Customer Directory mailing list (offers & updates) — NOT booking.
# NEXT_PUBLIC_SQUARE_MAILING_LIST_URL=https://squareup.com/customer-programs/enroll/hg4NM8qZXwGm?utm_source=...
# Square Outreach embed form (POST email_address) — on-site footer/contact signup:
# NEXT_PUBLIC_SQUARE_MAILING_LIST_SUBSCRIBE_URL=https://squareup.com/outreach/YRCeaX/subscribe

# Optional per-staff overrides (fall back to org BOOKING_URL).
# NEXT_PUBLIC_SQUARE_BOOKING_URL_DANIELLE=
# NEXT_PUBLIC_SQUARE_BOOKING_URL_RYAN=
# Legacy Fresha staff URLs (still honored as overrides if set):
# NEXT_PUBLIC_FRESHA_BOOKING_URL_DANIELLE=
# NEXT_PUBLIC_FRESHA_BOOKING_URL_RYAN=

# Charm EHR — clinical charting & e-prescribe (NOT patient booking).
# Patients book NP telehealth on Square (NEXT_PUBLIC_SQUARE_RX_TELEHEALTH_URL / lib/flows.ts).
# Patient portal default: https://phr.charmtracker.com/
# Optional: web-embed booking URL from Charm → Settings → Calendar → Web Embed (Ryan + Video Consult).
# NEXT_PUBLIC_CHARM_TELEHEALTH_BOOKING_URL=https://your-charm-web-embed-or-phr-link
# NEXT_PUBLIC_CHARM_PHR_URL=https://phr.charmtracker.com/

# Booking transition banner (top of site) — "false" to hide
NEXT_PUBLIC_BOOKING_BANNER_ACTIVE=true
# ============================================================
# GLP-1 INTAKE — native screening form at /glp1-intake (Supabase hg_form_submissions)
# Legacy IntakeQ embed (optional override — not required):
# NEXT_PUBLIC_INTAKEQ_GLP1_IFRAME_SRC=https://yourpractice.intakeq.com/...

# ============================================================
# TWILIO SMS (Required for transactional/marketing SMS)
# Get these from: https://console.twilio.com
# ============================================================

TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# A2P Messaging Service (preferred for marketing SMS — Hello Gorgeous Client Messages)
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx

# WhatsApp (Twilio) — E.164 without the whatsapp: prefix; Command Center + /api/hub/whatsapp/incoming
# TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX

# Local webhook testing only — never set in production
# TWILIO_WEBHOOK_SKIP_SIGNATURE=1

# ============================================================
# AI CONCIERGE (Sarah) — Twilio Voice → Claude → booking_requests
# Set in Vercel; verify on /admin/ai-concierge/health.
# Phase-1 webhook URL (paste into Twilio number Voice config):
#   https://www.hellogorgeousmedspa.com/api/ai-concierge/voice/incoming
# ============================================================
# Required for Sarah's brain (Claude). Without this, gather falls back to a stub.
# ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=
# Canonical webhook origin (no path). Used by /admin/ai-concierge/health to compute
# the Twilio webhook URL and by the diagnostics self-test so signatures match what
# Twilio actually calls. Falls back to NEXT_PUBLIC_SITE_URL, then to the request
# host (with `hub.` stripped). Set this on preview deploys if needed.
# NEXT_PUBLIC_AI_CONCIERGE_BASE_URL=https://www.hellogorgeousmedspa.com
# Where Sarah hands off if a caller asks for a human or a booking fails.
# E.164. Admin > AI Concierge > Settings overrides this at runtime.
# AI_CONCIERGE_TRANSFER_E164=+1XXXXXXXXXX
# Where post-call booking-summary SMS lands (alias: AI_CONCIERGE_NOTIFY_SMS).
# AI_CONCIERGE_STAFF_PHONE_E164=+1XXXXXXXXXX
# Override Resend `to` address for booking emails (defaults to SITE.email).
# AI_CONCIERGE_STAFF_EMAIL=
#
# Ring-first (Pattern B) — Twilio rings staff first, falls back to Sarah on
# no-answer/busy/failed. Admin > Settings is the live control; these env vars
# are only fallbacks when the settings row is missing.
# AI_CONCIERGE_RING_FIRST_ENABLED=true        # true|false (default true)
# AI_CONCIERGE_RING_FIRST_TIMEOUT=20           # seconds (5–60)
# AI_CONCIERGE_RING_FIRST_E164=+1XXXXXXXXXX    # defaults to AI_CONCIERGE_TRANSFER_E164

# ============================================================
# TELNYX VOICE (Optional — AI voice receptionist /api/voice/telnyx only)
# SMS does not use Telnyx; Twilio is used for all SMS.
# ============================================================
# TELNYX_API_KEY=
# TELNYX_WEBHOOK_PUBLIC_KEY=
# TELNYX_VOICE_TRANSFER_NUMBER=

# ============================================================
# ALTERNATIVE SMS PROVIDERS (Optional — lib/hgos/sms-marketing)
# ============================================================

# SimpleTexting
# SIMPLETEXTING_API_KEY=
# SIMPLETEXTING_ACCOUNT_PHONE=

# ============================================================
# EMAIL (Optional - for transactional emails)
# ============================================================

# Primary staff inbox — Google Payments, leads, booking alerts (lib/business-contact.ts)
# CONTACT_FORM_TO_EMAIL=provider@hellogorgeousmedspa.com
# BOOKING_NOTIFY_EMAIL=provider@hellogorgeousmedspa.com
# REVIEW_ALERT_EMAIL=provider@hellogorgeousmedspa.com
# Optional personal BCC on lead emails only (leave unset to deliver to ops inbox only):
# LEAD_EMAIL_BCC=

# SMS alert on website form submit (defaults to +16308813398 / REVIEW_ALERT_PHONE)
# FORM_ALERT_PHONE=+16308813398

# Resend (recommended for sending contact form submissions)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Hello Gorgeous Contact <onboarding@resend.dev>

# Google review asks: Fresha "Thank you for visiting" + Google Rating Boost (primary).
# Bulk backlog email (Mac review-daily-send.mjs + Vercel review-email-campaign cron) — OFF unless true:
# REVIEW_BULK_EMAIL_ENABLED=false
# Per-visit HG OS / Square webhook queue (hourly cron) — default on; set false to disable:
# REVIEW_REQUESTS_ENABLED=true

# Or SendGrid
# SENDGRID_API_KEY=SG...

# ============================================================
# GOOGLE (Optional - for reviews, analytics)
# ============================================================

# Google Places API (for review boost feature)
# GOOGLE_PLACES_API_KEY=

# Google Maps embed (optional). Footer/contact "Find Us" map needs one of these:
# Option A: Google Maps → search your business → Share → Embed a map → copy iframe src:
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
# Option B: Maps Embed API key (Google Cloud Console) for address-based embed:
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=AIza...
# If neither is set, we show a "View on Google Maps" link instead of a broken map.

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Business Profile API (Hub "Connect Google Business OAuth" + posting)
# 1) Google Cloud Console → enable "Google Business Profile API" (APIs & Services → Library).
# 2) APIs & Services → Credentials → Create OAuth client ID → Application type: Web application.
# 3) Authorized redirect URI (must match NEXT_PUBLIC_APP_URL / BASE_URL, no trailing slash):
#    https://www.hellogorgeousmedspa.com/api/auth/google/callback
#    (Use your real production domain; www vs non-www must match what the app uses.)
# 4) Vercel → Environment Variables (not an in-app "Settings" page):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# After deploy, open Hub → Connect Google Business OAuth — tokens save to Supabase hg_oauth_tokens.
# Some routes still read these from env (e.g. posting); set if prompted after OAuth:
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_BUSINESS_ACCOUNT_ID=
# GOOGLE_BUSINESS_LOCATION_ID=
#
# Google Search Console — sitemap submission + URL inspection
# Reuses GOOGLE_CLIENT_ID/SECRET above. Capture this token via
# /api/seo/google-connect (one-time OAuth grant for the
# `webmasters` scope). See docs/GOOGLE_SEARCH_CONSOLE_SETUP.md.
# GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
#
# Meta Graph (Facebook / Instagram posting)
# Hello Gorgeous Med Spa Page (default admin + med spa posts)
# META_PAGE_ID=
# META_PAGE_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=          # optional alias for META_PAGE_ID
# FACEBOOK_PAGE_ACCESS_TOKEN= # optional alias for META_PAGE_ACCESS_TOKEN
# META_INSTAGRAM_BUSINESS_ACCOUNT_ID=
# META_IG_ACCOUNT_ID=
#
# RE GEN dedicated Page — https://www.facebook.com/profile.php?id=61591289596151
# RE GEN social calendar (scripts/publish-regen-social-calendar.ts) uses metaBrand=regen.
# META_REGEN_PAGE_ID=61591289596151
# META_REGEN_PAGE_ACCESS_TOKEN=  # optional; falls back to META_PAGE_ACCESS_TOKEN
# META_REGEN_INSTAGRAM_BUSINESS_ACCOUNT_ID=  # when IG is linked to Re Gen RX Page

# Weekly queue: inserts 7 scheduled Facebook posts (presets) — requires Supabase + CRON_SECRET.
# Vercel Cron hits GET /api/cron/queue-suggested-week (see vercel.json). Off by default.
# SOCIAL_AUTO_QUEUE_ENABLED=true

# Win-Back Agent: auto-sends SMS to lapsed clients (90+ days) every Monday.
# Set to "true" ONLY when you're ready — this sends real SMS to real people.
# WINBACK_AGENT_ENABLED=true

# Lead Nurture Agent: auto-sends welcome SMS + follow-up emails to new leads (daily).
# LEAD_NURTURE_ENABLED=true

# Birthday Agent: auto-sends birthday offers on the 1st of each month.
# BIRTHDAY_AGENT_ENABLED=true

# ============================================================
# COMMAND CENTER /hub (optional password gate + signed session)
# If HUB_PASSWORD_DANI or HUB_PASSWORD_RYAN is set, /hub and /api/hub/* require login.
# hub. subdomain rewrites to /hub (set DNS + Vercel domain).
# ============================================================
# HUB_PASSWORD_DANI=
# HUB_PASSWORD_RYAN=
# HUB_SESSION_SECRET=

# ============================================================
# STAFF TRAINING HUB (/staff) — shared team PIN
# Protects /staff, /staff/protocols, and all /staff/* PDFs & assets.
# Set in Vercel production env. Admin /login (owner/admin/staff/provider) bypasses PIN.
# ============================================================
STAFF_PORTAL_PIN=070726
# STAFF_SESSION_SECRET=

# ============================================================
# AI CONCIERGE VOICE (Twilio + Sarah) — OFF by default Jul 2026
# Main line uses Comcast voicemail. Set true only if re-enabling Twilio voice.
# ============================================================
AI_CONCIERGE_VOICE_ENABLED=false

# ============================================================
# PLAID — Hub bank connections (HG_DEV_PLAID_001)
# https://dashboard.plaid.com — use Sandbox secret until Production approved.
# Encrypts Item access tokens with SQUARE_ENCRYPTION_KEY or PLAID_ENCRYPTION_KEY (64 hex chars).
# ============================================================
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_ENCRYPTION_KEY=
# Daily sync: Vercel Cron GET /api/hub/plaid/sync with Authorization: Bearer CRON_SECRET

# ============================================================
# SQUARE (Required for POS/Terminal Payments)
# Get these from: https://developer.squareup.com/apps
# ============================================================

# Application ID (server-only)
SQUARE_APPLICATION_ID=
# Optional fallback bearer token. Hub /api/hub/square-summary prefers OAuth (Admin → Connect Square)
# in Supabase square_connections; set this only if OAuth is not connected.
# SQUARE_ACCESS_TOKEN=

# OAuth credentials (server-only - NO NEXT_PUBLIC_*)
SQUARE_OAUTH_CLIENT_ID=
SQUARE_OAUTH_CLIENT_SECRET=

# Token encryption key (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
SQUARE_ENCRYPTION_KEY=

# Webhook signature verification key
# Get from: Square Dashboard > Your App > Webhooks > Signature Key
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Optional but recommended if you still see 401 Invalid signature in production:
# Must match the notification URL in Square EXACTLY (https, www or not, path — no trailing slash).
# Example: https://www.hellogorgeousmedspa.com/api/square/webhook
# The webhook handler also derives the URL from the incoming request; set this if behind a proxy mismatch.
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Environment: sandbox or production
SQUARE_ENVIRONMENT=sandbox

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Canonical server URL (used for OAuth callbacks, webhooks fallback)
# For Square HMAC, prefer matching www with your live site and Dashboard, or use SQUARE_WEBHOOK_NOTIFICATION_URL
BASE_URL=https://www.hellogorgeousmedspa.com

# Public URL for UI display (can be same as BASE_URL)
NEXT_PUBLIC_BASE_URL=https://hellogorgeousmedspa.com

# "The Book" digital edition — Square Payment Link or Online Store checkout URL (paste from Square Dashboard)
# NEXT_PUBLIC_BOOK_SQUARE_CHECKOUT_URL=https://square.link/...

# Legacy app URL (kept for backward compatibility)
NEXT_PUBLIC_APP_URL=https://hellogorgeousmedspa.com

# Environment: development, staging, production
NODE_ENV=production

# Booking & reviews (first-party by default; no Fresha)
# Leave unset to use /book and /reviews on your site
# NEXT_PUBLIC_BOOKING_URL=/book
# NEXT_PUBLIC_REVIEWS_URL=https://www.hellogorgeousmedspa.com/reviews

# Trigger Point video (legacy - YouTube or direct URL)
# NEXT_PUBLIC_TRIGGER_POINT_VIDEO_URL=https://youtu.be/YOUR_VIDEO_ID

# Cloudflare Stream (recommended for video uploads - Admin → Media)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_STREAM_API_TOKEN=your_stream_api_token
# NEXT_PUBLIC_STREAM_CUSTOMER_CODE=optional_for_hls

# CareCredit — Hello Gorgeous provider link (optional; defaults to TQR425)
# NEXT_PUBLIC_CARECREDIT_URL=https://www.carecredit.com/go/TQR425

# ============================================================
# CREATOMATE (Required for Video Generator)
# Get these from: https://creatomate.com/dashboard
# ============================================================

# API key from Project Settings
# CREATOMATE_API_KEY=

# Template IDs - create 3 templates in Creatomate editor
# with text layers: Headline, Price, OriginalPrice, PromoLabel,
# Benefit1-4, ServiceName, Phone, Website
# CREATOMATE_TEMPLATE_VERTICAL=
# CREATOMATE_TEMPLATE_SQUARE=
# CREATOMATE_TEMPLATE_HORIZONTAL=

# ============================================================
# HELLO GORGEOUS RX — Pharmacy / FormuConnect (Provider Portal)
# ============================================================
# Keep false until Formulation / FormuConnect credentials + live client exist (Phase 6).
# RX_PHARMACY_API_ENABLED=false
# Optional public vendor Place Order URLs (Provider Portal deep-links):
# NEXT_PUBLIC_FORMULATION_PORTAL_URL=https://portal.formuconnect.com/login
# NEXT_PUBLIC_BOOMRX_PORTAL_URL=https://hub.wellsync.com/en-US/boomrx/auth/login?redirect_url=https%3A%2F%2Fportal.boomrx.com%2Fen-US%2Fboomrx&mode=login
# NEXT_PUBLIC_OLYMPIA_PORTAL_URL=https://olympiapharmacy.drscriptportal.com
# Live API credentials (server-only; never expose to client):
# FORMULATION_API_KEY=
# FORMUCONNECT_API_KEY=
# FORMULATION_CLIENT_ID=
# FORMULATION_CLIENT_SECRET=

# ============================================================
# SECURITY NOTES
# ============================================================
# 
# 1. NEVER commit .env.local or any file containing real keys
# 2. Rotate keys immediately if they are ever exposed
# 3. Use different keys for development and production
# 4. Limit service role key usage to server-side only
# 5. Enable Supabase RLS (Row Level Security) on all tables
# 
# For production deployment on Vercel:
# - Add all these variables in Project Settings > Environment Variables
# - Use "Production" environment for live keys
# - Use "Preview" environment for test keys
# ============================================================
