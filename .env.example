# ============================================================
# HELLO GORGEOUS OS - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# 
# IMPORTANT: Never commit .env.local to version control!
# ============================================================

# ============================================================
# SUPABASE (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ============================================================

# Public URL - safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key - safe to expose, used for client-side queries
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - KEEP SECRET! Only use server-side
# This key bypasses Row Level Security - never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# STRIPE (Required for Payments)
# Get these from: https://dashboard.stripe.com/apikeys
# ============================================================

# Use LIVE keys for production (sk_live_..., pk_live_...)
# Use TEST keys for development (sk_test_..., pk_test_...)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret - get from Stripe Dashboard > Webhooks
# Required to verify webhook events are from Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# BOOKING TRANSITION (Optional)
# Fresha → Hello Gorgeous OS migration banner
# Set to "false" to disable the top announcement banner post-migration
# ============================================================
# NEXT_PUBLIC_BOOKING_TRANSITION_ACTIVE=true

# ============================================================
# GLP-1 INTAKE (Optional — IntakeQ HIPAA form embed on /glp1-intake)
# Paste the full iframe src URL from IntakeQ after the form is published.
# ============================================================
# NEXT_PUBLIC_INTAKEQ_GLP1_IFRAME_SRC=https://yourpractice.intakeq.com/...

# ============================================================
# TWILIO SMS (Required for transactional/marketing SMS)
# Get these from: https://console.twilio.com
# ============================================================

TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ============================================================
# TELNYX VOICE (Optional — AI voice receptionist /api/voice/telnyx only)
# SMS does not use Telnyx; Twilio is used for all SMS.
# ============================================================
# TELNYX_API_KEY=
# TELNYX_WEBHOOK_PUBLIC_KEY=
# TELNYX_VOICE_TRANSFER_NUMBER=

# ============================================================
# ALTERNATIVE SMS PROVIDERS (Optional — lib/hgos/sms-marketing)
# ============================================================

# SimpleTexting
# SIMPLETEXTING_API_KEY=
# SIMPLETEXTING_ACCOUNT_PHONE=

# ============================================================
# EMAIL (Optional - for transactional emails)
# ============================================================

# Contact form destination (defaults to SITE.email in lib/seo.ts if unset)
# CONTACT_FORM_TO_EMAIL=hellogorgeousskin@yahoo.com

# Resend (recommended for sending contact form submissions)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Hello Gorgeous Contact <onboarding@resend.dev>

# Or SendGrid
# SENDGRID_API_KEY=SG...

# ============================================================
# GOOGLE (Optional - for reviews, analytics)
# ============================================================

# Google Places API (for review boost feature)
# GOOGLE_PLACES_API_KEY=

# Google Maps embed (optional). Footer/contact "Find Us" map needs one of these:
# Option A: Google Maps → search your business → Share → Embed a map → copy iframe src:
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...
# Option B: Maps Embed API key (Google Cloud Console) for address-based embed:
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=AIza...
# If neither is set, we show a "View on Google Maps" link instead of a broken map.

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# SQUARE (Required for POS/Terminal Payments)
# Get these from: https://developer.squareup.com/apps
# ============================================================

# Application ID (server-only)
SQUARE_APPLICATION_ID=

# OAuth credentials (server-only - NO NEXT_PUBLIC_*)
SQUARE_OAUTH_CLIENT_ID=
SQUARE_OAUTH_CLIENT_SECRET=

# Token encryption key (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
SQUARE_ENCRYPTION_KEY=

# Webhook signature verification key
# Get from: Square Dashboard > Your App > Webhooks > Signature Key
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Optional but recommended if you still see 401 Invalid signature in production:
# Must match the notification URL in Square EXACTLY (https, www or not, path — no trailing slash).
# Example: https://www.hellogorgeousmedspa.com/api/square/webhook
# The webhook handler also derives the URL from the incoming request; set this if behind a proxy mismatch.
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Environment: sandbox or production
SQUARE_ENVIRONMENT=sandbox

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Canonical server URL (used for OAuth callbacks, webhooks fallback)
# For Square HMAC, prefer matching www with your live site and Dashboard, or use SQUARE_WEBHOOK_NOTIFICATION_URL
BASE_URL=https://www.hellogorgeousmedspa.com

# Public URL for UI display (can be same as BASE_URL)
NEXT_PUBLIC_BASE_URL=https://hellogorgeousmedspa.com

# Legacy app URL (kept for backward compatibility)
NEXT_PUBLIC_APP_URL=https://hellogorgeousmedspa.com

# Environment: development, staging, production
NODE_ENV=production

# Booking & reviews (first-party by default; no Fresha)
# Leave unset to use /book and /reviews on your site
# NEXT_PUBLIC_BOOKING_URL=/book
# NEXT_PUBLIC_REVIEWS_URL=https://www.hellogorgeousmedspa.com/reviews

# Trigger Point video (legacy - YouTube or direct URL)
# NEXT_PUBLIC_TRIGGER_POINT_VIDEO_URL=https://youtu.be/YOUR_VIDEO_ID

# Cloudflare Stream (recommended for video uploads - Admin → Media)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_STREAM_API_TOKEN=your_stream_api_token
# NEXT_PUBLIC_STREAM_CUSTOMER_CODE=optional_for_hls

# CareCredit — Hello Gorgeous provider link (optional; defaults to TQR425)
# NEXT_PUBLIC_CARECREDIT_URL=https://www.carecredit.com/go/TQR425

# ============================================================
# CREATOMATE (Required for Video Generator)
# Get these from: https://creatomate.com/dashboard
# ============================================================

# API key from Project Settings
# CREATOMATE_API_KEY=

# Template IDs - create 3 templates in Creatomate editor
# with text layers: Headline, Price, OriginalPrice, PromoLabel,
# Benefit1-4, ServiceName, Phone, Website
# CREATOMATE_TEMPLATE_VERTICAL=
# CREATOMATE_TEMPLATE_SQUARE=
# CREATOMATE_TEMPLATE_HORIZONTAL=

# ============================================================
# SECURITY NOTES
# ============================================================
# 
# 1. NEVER commit .env.local or any file containing real keys
# 2. Rotate keys immediately if they are ever exposed
# 3. Use different keys for development and production
# 4. Limit service role key usage to server-side only
# 5. Enable Supabase RLS (Row Level Security) on all tables
# 
# For production deployment on Vercel:
# - Add all these variables in Project Settings > Environment Variables
# - Use "Production" environment for live keys
# - Use "Preview" environment for test keys
# ============================================================
